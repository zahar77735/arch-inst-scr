#!/bin/bash
clear
loadkeys ru
setfont cyr-sun16
#echo 'Скрипт сделан на основе чеклиста Бойко Алексея по Установке ArchLinux'
#echo 'Ссылка на чек лист есть в группе vk.com/arch4u'

echo 'Синхронизация системных часов'
timedatectl set-ntp true

echo 'Создание разделов'

echo 'Ваша разметка диска'
lsblk

disk=$(test -d /sys/firmware/efi && echo efi || echo bios)
if [[ $disk == efi ]]; then
  read -p 'Выбрать диск? ' xhdd
  fdisk /dev/$xhdd
  read -p "Выберите раздел куда будет установлена система: " rootsection
  read -p "Введите имя метки тома: " mark
  read -p "Выберите раздел для boot: " efi
  mkfs.f2fs -f -l "$mark" /dev/$rootsection
  mkfs.fat -F32 /dev/$efi
  mount /dev/$rootsection /mnt
  mkdir -p /mnt/boot
  mkdir -p /mnt/boot/efi
  mount -t vfat /dev/$efi /mnt/boot/efi
elif [[ $disk == bios ]]; then
  read -p 'Выбрать диск? ' xhdd
  fdisk /dev/$xhdd
  read -p "Выберите раздел куда будет установлена система: " rootsection
  read -p "Введите имя метки тома: " mark
  mkfs.f2fs -f -l "$mark" /dev/$rootsection
  mount /dev/$rootsection /mnt
fi

echo 'Выбор зеркал для загрузки.'
nano /etc/pacman.d/mirrorlist
nano /etc/pacman.conf
pacman -Sy

echo 'Установка основных пакетов'
pacstrap /mnt base base-devel linux-zen linux-firmware linux-zen-headers intel-ucode nano sudo f2fs-tools e2fsprogs

genfstab -pU /mnt >> /mnt/etc/fstab

arch-chroot /mnt sh -c "$(curl -fsSL git.io/inst2)"
